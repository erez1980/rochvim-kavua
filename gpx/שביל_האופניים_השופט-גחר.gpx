	<metadata>
		<bounds minlat="32.599742" minlon="35.100886" maxlat="32.6276928" maxlon="35.1332639" />
	</metadata>
	<trk>
		<name>סינגל גחר 1</name>
		<desc>רכיבה חלומית ביער רמת מנשה הקסום המתאים לרכיבה כל השנה. סיבוב בסימון כחול נגד כיוון השעון. אפשר להתחיל למעלה ליד בית הספר בעין השופט או עדיף בעמק קרוב לכביש 66. מעולה במיוחד בחיבור עם סינגל השופט בצירוף הפופולרי "צהוב-כחול".</desc>
		<extensions>
			<Color xmlns="">#FF6600</Color>
			<Opacity xmlns="">0.8</Opacity>
			<Weight xmlns="">8</Weight>
		</extensions>
